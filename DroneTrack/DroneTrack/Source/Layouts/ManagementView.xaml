<UserControl x:Class="DroneTrack.Source.Layouts.ManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DroneTrack.Source.Layouts"
             xmlns:elements="clr-namespace:DroneTrack.Source.Elements"
             
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Drones List" FontWeight="Bold" Margin="10"/>
                    <ListBox ItemsSource="{Binding AllDrones}"
                             DisplayMemberPath="ModelType"/>
                    <Button Content="Clear Filters" Margin="10"/>
                </StackPanel>
            </Border>

            <wv2:WebView2 Grid.Column="1" x:Name="MainMap" />

            <Border Grid.Column="2" Width="300" Background="White" 
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="15">
                    <TextBlock Text="Flight Details" FontWeight="Bold" FontSize="16"/>
                    <Button Content="Update" Background="Green" Foreground="White" Margin="0,20"/>
                </StackPanel>
            </Border>
        </Grid>

        <elements:TimeRangeSlider Grid.Row="1" Margin="5" x:Name="MissionTimeFilter" 
                TimeFrom="{Binding SelectedStart, Mode=TwoWay}" 
                TimeTo="{Binding SelectedEnd, Mode=TwoWay}"/>
    </Grid>
</UserControl>
