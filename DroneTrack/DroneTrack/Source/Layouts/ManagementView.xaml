<UserControl x:Class="DroneTrack.Source.Layouts.ManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DroneTrack.Source.Layouts"
             xmlns:elements="clr-namespace:DroneTrack.Source.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Drones List" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Row="1" Content="Clear Filters" Margin="5" Command="{Binding ClearFiltersCommand}"/>
                    <ListBox Grid.Row="2" ItemsSource="{Binding AllFlights}"
                             SelectedItem="{Binding SelectedFlight, Mode=TwoWay}"
                             DisplayMemberPath="FullDisplayName"/>
                </Grid>
            </Border>

            <Border Grid.Column="1">
                <elements:Map></elements:Map>
            </Border>
            
            <Border Grid.Column="2" Width="300" Background="White" 
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="15">
                    <TextBlock Text="Flight Details" FontWeight="Bold"/>

                    <Button Content="Edit"
                    Command="{Binding FlightDetailsViewModel.ToggleEditModeCommand}"
                    Background="Gray" 
                    Foreground="White" 
                    Margin="0,10"/>

                    <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Background="DeepSkyBlue" 
                    Foreground="White" 
                    Margin="0,10"/>

                    <TextBlock Text="{Binding SelectedFlight.Id, StringFormat='ID lotu : {0}'}" Margin="15,5"/>

                    <Grid Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Operator -->
                        <TextBlock Grid.Row="0"
               Grid.Column="0"
               Text="Operator:"
               VerticalAlignment="Center"
               Margin="0,5"/>

                        <TextBox Grid.Row="0"
             Grid.Column="1"
             Text="{Binding SelectedFlight.OperatorIdentity, Mode=TwoWay}"
             IsEnabled="{Binding FlightDetailsViewModel.IsEditMode}"
             Margin="0,5"/>

                        <!-- Dron -->
                        <TextBlock Grid.Row="1"
               Grid.Column="0"
               Text="Dron:"
               VerticalAlignment="Center"
               Margin="0,5"/>

                        <ComboBox Grid.Row="1"
              Grid.Column="1"
              ItemsSource="{Binding FlightDetailsViewModel.AvailableDrones}"
              SelectedItem="{Binding FlightDetailsViewModel.FlightDrone, Mode=TwoWay}"
              DisplayMemberPath="ModelType"
              IsEnabled="{Binding FlightDetailsViewModel.IsEditMode}"
              Margin="0,5"/>

                        <!-- Czas misji -->
                        <TextBlock Grid.Row="2"
               Grid.Column="0"
               Text="Czas misji:"
               VerticalAlignment="Center"
                                   Margin="0,5"/>

                        <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Text="{Binding SelectedFlight.FlightDateStart}"
                     IsEnabled="{Binding FlightDetailsViewModel.IsEditMode}"
                                 Margin="0,5"/>
                    </Grid>

                    <StackPanel Margin="15" DataContext="{Binding SelectedFlight}">
                            <TextBlock Text="Czas misji"/>
                            <TextBlock Text="{Binding FlightDateStart, StringFormat='Od : {0}'}"/>
                            <TextBlock Text="{Binding FlightDateEnd, StringFormat='Do: {0}'}"/>
                            <TextBlock Text="{Binding Latitude, StringFormat='Szerokość: {0} (Lat)'}"/>
                            <TextBlock Text="{Binding Longitude, StringFormat='Długość: {0} (Lng)'}"/>
                            <TextBlock Text="{Binding MaxAltitude, StringFormat='Max wysokosc: {0}'}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <elements:TimeRangeSlider Grid.Row="1" Margin="5" x:Name="MissionTimeFilter" 
                TimeFrom="{Binding SelectedStart, Mode=TwoWay}" 
                TimeTo="{Binding SelectedEnd, Mode=TwoWay}"
                SelectedDate="{Binding SelectedDate, Mode=TwoWay}"/>
    </Grid>
</UserControl>
