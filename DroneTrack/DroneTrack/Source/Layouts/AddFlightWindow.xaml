<Window x:Class="DroneTrack.Source.Layouts.AddFlightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DroneTrack.Source.Layouts"
        mc:Ignorable="d"
        Title="Dodaj nowy lot" Height="525" Width="400">
    <StackPanel Margin="20">
        <TextBlock Text="DANE LOKALIZACJI" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gray"/>

        <UniformGrid Columns="2">
            <TextBlock Text="Szerokość (Lat):"/>
            <TextBlock Text="{Binding Lat}" FontWeight="SemiBold"/>
            <TextBlock Text="Długość (Lng):"/>
            <TextBlock Text="{Binding Lng}" FontWeight="SemiBold"/>
            <TextBlock Text="Czas zgłoszenia:"/>
            <TextBlock Text="{Binding CurrentTime}" Foreground="Blue"/>
        </UniformGrid>

        <Separator Margin="0,15"/>

        <TextBlock Text="ID Operatora:" Margin="0,5,0,0"/>
        <TextBox Text="{Binding OperatorId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <TextBlock Text="Dron:" Margin="0,5,0,0"/>
        <ComboBox ItemsSource="{Binding AvailableDrones}" 
                  SelectedItem="{Binding SelectedDrone}"
                  DisplayMemberPath="ModelType" />

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,10">
                <TextBlock Text="Opóźnienie (min):"/>
                <TextBox Text="{Binding DelayMinutes}"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,10">
                <TextBlock Text="Czas lotu (min):"/>
                <TextBox Text="{Binding DurationMinutes}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Max Wysokość (m):"/>
                <TextBox Text="{Binding MaxAltitude}"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Opis dodatkowy:" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Description}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Button Content="Zatwierdź lot" 
                Command="{Binding SaveFlightCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Margin="0,20,0,0" Height="35" Background="LightGreen" FontWeight="Bold"/>
    </StackPanel>
</Window>
