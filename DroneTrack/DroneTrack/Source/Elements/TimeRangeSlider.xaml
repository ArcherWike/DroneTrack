<UserControl x:Class="DroneTrack.Source.Elements.TimeRangeSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DroneTrack.Source.Elements"
             mc:Ignorable="d" 
             d:DesignHeight="45" d:DesignWidth="*">
    <UserControl.Resources>
        <Style x:Key="CustomSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Ellipse Fill="#2196F3" Stroke="White" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="5,0,5,10" VerticalAlignment="Bottom">
            <TextBlock Text="Date" FontWeight="Bold" Margin="0,0,0,5" Foreground="#123456"/>
            <DatePicker x:Name="MissionDatePicker" Width="130" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
            <TextBlock x:Name="TimeLabel" 
                   Text="08:00 - 16:00" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,0"
                   Foreground="#004080"/>

            <Grid Height="40" Margin="5,10">
                <Rectangle Height="5" Fill="#EEEEEE" RadiusX="2"/>

                <Slider x:Name="StartSlider" Minimum="0" Maximum="1440" Value="480" 
                    TickFrequency="15" IsSnapToTickEnabled="True"
                    Style="{StaticResource CustomSliderStyle}"/>

                <Slider x:Name="EndSlider" Minimum="0" Maximum="1440" Value="960" 
                    TickFrequency="15" IsSnapToTickEnabled="True"
                    Style="{StaticResource CustomSliderStyle}"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
