<Window
    x:Class="DroneTrack.Source.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DroneTrack"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:DroneTrack.Source.Layouts"
    xmlns:vms="clr-namespace:DroneTrack.Source.ViewModels"
    Title="Drone Management System"
    Width="800"
    Height="450"
    mc:Ignorable="d">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vms:ManagementViewModel}">
            <views:ManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:UserViewModel}">
            <views:UserView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:FlightDetailsViewModel}">
            <views:FlightDetailsPanel />
        </DataTemplate>
    </Window.Resources>


    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="15,0"
            Background="#1A202C">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <RadioButton
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Settings"
                    Content="⚙"
                    FontSize="24"
                    Style="{StaticResource MenuButtonStyle}" />
                <RadioButton
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Management"
                    Content="MANAGEMENT"
                    IsChecked="True"
                    Style="{StaticResource MenuButtonStyle}" />
                <RadioButton
                    Margin="20,0"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="User"
                    Content="USER MODE"
                    Style="{StaticResource MenuButtonStyle}" />
            </StackPanel>
        </Border>
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
    </Grid>
</Window>
