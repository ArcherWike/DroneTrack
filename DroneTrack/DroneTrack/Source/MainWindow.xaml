<Window x:Class="DroneTrack.Source.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DroneTrack"
        mc:Ignorable="d"
        
        xmlns:vms="clr-namespace:DroneTrack.Source.ViewModels"
        
        xmlns:views="clr-namespace:DroneTrack.Source.Layouts"
        
        Title="Drone Management System" Height="450" Width="800">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vms:ManagementViewModel}">
            <views:ManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:UserViewModel}">
            <views:UserView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>


    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1A202C" Grid.Row="0" Padding="15,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton Content="MANAGEMENT" 
                             Style="{StaticResource MenuButtonStyle}"
                             Command="{Binding NavigateCommand}" 
                             CommandParameter="Management"
                             IsChecked="True"/>
                <RadioButton Content="USER MODE" 
                             Style="{StaticResource MenuButtonStyle}"
                             Command="{Binding NavigateCommand}" 
                             CommandParameter="User"
                             Margin="20,0"/>

                <Button Content="⚙" 
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="Settings"
                        Style="{StaticResource SettingsButtonStyle}"
                        HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
    </Grid>
</Window>
